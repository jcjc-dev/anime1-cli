{
  "name": "anime1-core",
  "version": "0.2.0",
  "description": "Engine for browsing and downloading from anime1.me. No UI, no runtime dependencies.",
  "keywords": [
    "anime1",
    "anime",
    "downloader"
  ],
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcjc-dev/anime1-cli.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/jcjc-dev/anime1-cli/tree/main/packages/core#readme",
  "bugs": "https://github.com/jcjc-dev/anime1-cli/issues",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit && eslint src",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  }
}
