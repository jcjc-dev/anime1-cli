{
  "name": "anime1-cli",
  "version": "0.1.1",
  "description": "Interactive CLI to browse anime1.me by year and season and download episodes. Self-contained, no system dependencies.",
  "keywords": [
    "anime1",
    "anime",
    "downloader",
    "cli"
  ],
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcjc-dev/anime1-cli.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/jcjc-dev/anime1-cli#readme",
  "bugs": "https://github.com/jcjc-dev/anime1-cli/issues",
  "bin": {
    "anime1": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "lint": "tsc -p tsconfig.json --noEmit && eslint src",
    "test": "vitest run",
    "start": "node dist/cli.js",
    "prepack": "npm run build"
  },
  "dependencies": {
    "anime1-core": "^0.1.1",
    "@inquirer/prompts": "^8.5.2",
    "commander": "^15.0.0"
  }
}
